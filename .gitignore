# Per-developer Tauri config overrides (e.g. iOS free-signing Team ID)
src-tauri/tauri.*.local.conf.json

# Tauri iOS — regenerated by `npm run tauri ios init` from project.yml.
# Tracking these caused churn: Xcode writes DEVELOPMENT_TEAM (Team ID leak) into pbxproj
# on every build, and reformats arrays / adds lastKnownFileType hints. The scheme file
# mutates similarly. See docs/ios-developer-setup.md for the one-time regen step.
src-tauri/gen/apple/localmind.xcodeproj/project.pbxproj
src-tauri/gen/apple/localmind.xcodeproj/xcshareddata/xcschemes/*.xcscheme

# Local model and binary caches (in case anything escapes ~/Library)
*.gguf
*.safetensors
*.bin
bin/llama-server*
bin/sd*
